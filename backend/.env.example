# FaceMortgage - Environment Configuration
# Copy to .env and fill in values

# ===================
# Database
# ===================
DATABASE_URL=sqlite+aiosqlite:///./facemortgage.db
# For production: postgresql+asyncpg://user:password@host:5432/facemortgage

# ===================
# Redis
# ===================  
REDIS_URL=redis://localhost:6379/0

# ===================  
# Security
# ===================
SECRET_KEY=your-32-character-secret-key-here!!
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ===================
# Sentry (Error Monitoring)
# ===================
SENTRY_DSN=
# Get from https://sentry.io - create project and copy DSN
# Example: https://abc123@o123456.ingest.sentry.io/1234567

# ===================
# External Services (Optional for Demo)
# ===================
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

SENDGRID_API_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===================
# Feature Flags
# ===================
DEMO_MODE=true
VIDEO_CALLS_ENABLED=false
REAL_NMLS_LOOKUP=false
WEBSOCKET_ENABLED=true
