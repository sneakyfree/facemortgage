# =============================================================================
# FaceMortgage Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all required values.
# NEVER commit .env files to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
DEBUG=false
ENVIRONMENT=production
LOG_LEVEL=INFO
SECRET_KEY=  # REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"

# -----------------------------------------------------------------------------
# Sentry Error Tracking
# -----------------------------------------------------------------------------
# Get your DSN from https://sentry.io
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Use a connection pooler like PgBouncer in production
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/facemortgage
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Use Redis Cluster or managed Redis (AWS ElastiCache, etc.) in production
REDIS_URL=redis://:password@host:6379/0

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# List of allowed origins (your frontend domains)
CORS_ORIGINS=["https://facemortgage.com","https://www.facemortgage.com","https://app.facemortgage.com"]

# -----------------------------------------------------------------------------
# Stripe Payment Processing
# -----------------------------------------------------------------------------
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...  # REQUIRED for payments
STRIPE_WEBHOOK_SECRET=whsec_...  # REQUIRED for webhooks
# Create Price objects in Stripe Dashboard and get IDs
STRIPE_PRICE_ID_BASIC=price_...
STRIPE_PRICE_ID_PROFESSIONAL=price_...
STRIPE_PRICE_ID_PREMIUM=price_...

# Frontend URL (for Stripe redirects after checkout)
FRONTEND_URL=https://facemortgage.com

# -----------------------------------------------------------------------------
# External Data Provider
# -----------------------------------------------------------------------------
# Options: datagod, reeder, modex, corelogic
DATA_PROVIDER=datagod
DATA_PROVIDER_API_KEY=
DATA_PROVIDER_BASE_URL=
DATA_CACHE_TTL_HOURS=24

# -----------------------------------------------------------------------------
# WebRTC / TURN Server
# -----------------------------------------------------------------------------
# Required for video calls to work behind NAT/firewalls
# Use a TURN server provider like Twilio, Xirsys, or self-hosted coturn
TURN_SERVER_URL=turn:turn.facemortgage.com:3478
TURN_SERVER_USERNAME=
TURN_SERVER_CREDENTIAL=

# -----------------------------------------------------------------------------
# Email (SendGrid)
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=SG.xxx  # REQUIRED for transactional emails
FROM_EMAIL=noreply@facemortgage.com

# -----------------------------------------------------------------------------
# SMS (Twilio)
# -----------------------------------------------------------------------------
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=+1xxxxxxxxxx

# -----------------------------------------------------------------------------
# Video Storage
# -----------------------------------------------------------------------------
VIDEO_STORAGE_PATH=/var/facemortgage/uploads/videos
VIDEO_MAX_SIZE_MB=100
VIDEO_MAX_DURATION_SECONDS=60

# -----------------------------------------------------------------------------
# Cloud Storage (S3/R2/Compatible)
# -----------------------------------------------------------------------------
# Options: local, s3, r2
STORAGE_BACKEND=s3

# AWS Credentials (or IAM role if running on AWS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# S3 Bucket Configuration
S3_BUCKET_NAME=facemortgage-uploads
# For Cloudflare R2 or S3-compatible storage:
S3_ENDPOINT_URL=
# CDN URL for public access to uploaded files
S3_PUBLIC_URL_BASE=https://cdn.facemortgage.com

# =============================================================================
# Security Checklist for Production
# =============================================================================
# [ ] Generate a strong SECRET_KEY (at least 64 characters)
# [ ] Use SSL/TLS for all connections (database, Redis, API)
# [ ] Set up proper firewall rules
# [ ] Enable database encryption at rest
# [ ] Configure backup procedures for database
# [ ] Set up monitoring and alerting (Sentry, Datadog, etc.)
# [ ] Review CORS origins to only include your domains
# [ ] Ensure all API endpoints are properly authenticated
# [ ] Enable rate limiting at the load balancer level
# [ ] Set up log aggregation (ELK, CloudWatch, etc.)
# =============================================================================
