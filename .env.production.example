# Production environment variables template
# Copy to .env.production and fill in values

# Database
POSTGRES_USER=facemortgage
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=facemortgage

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Application
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL
ENVIRONMENT=production
CORS_ORIGINS=https://facemortgage.com,https://www.facemortgage.com

# Docker Registry
DOCKER_REGISTRY=ghcr.io/yourorg
IMAGE_TAG=latest

# URLs
API_URL=https://api.facemortgage.com
WS_URL=wss://api.facemortgage.com

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# SendGrid
SENDGRID_API_KEY=SG.xxx

# Sentry
SENTRY_DSN=https://xxx@sentry.io/xxx

# Google OAuth
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
