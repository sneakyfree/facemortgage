# ============================================================
# FaceMortgage — Master Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Required fields are marked [REQUIRED].
# Optional fields have sensible defaults.
# ============================================================

# ─────────────── Application ───────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
FRONTEND_URL=http://localhost:3000

# ─────────────── Security [REQUIRED in production] ───────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─────────────── Database [REQUIRED] ───────────────
DATABASE_URL=postgresql+asyncpg://facemortgage:facemortgage_dev@localhost:5432/facemortgage

# ─────────────── Redis [REQUIRED] ───────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────── TimescaleDB (Metrics) ───────────────
# TIMESCALE_DATABASE_URL=postgresql://facemortgage_metrics:metrics_dev@localhost:5433/facemortgage_metrics

# ─────────────── Stripe [REQUIRED for billing] ───────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_BASIC=price_...
STRIPE_PRICE_ID_PROFESSIONAL=price_...
STRIPE_PRICE_ID_PREMIUM=price_...
# Frontend (prefix with NEXT_PUBLIC_ in frontend/.env)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─────────────── SendGrid [REQUIRED for email] ───────────────
SENDGRID_API_KEY=SG....
FROM_EMAIL=noreply@facemortgage.com

# ─────────────── Twilio (SMS) ───────────────
# TWILIO_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE=+1...

# ─────────────── WebRTC / TURN [REQUIRED for video calls] ───────────────
# Obtain from Twilio, Xirsys, or Metered.ca
TURN_SERVER_URL=turn:global.turn.twilio.com:3478?transport=udp
TURN_SERVER_USERNAME=
TURN_SERVER_CREDENTIAL=

# ─────────────── LiveKit (optional scalable video) ───────────────
USE_LIVEKIT=false
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

# ─────────────── Web Push (VAPID) ───────────────
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@facemortgage.com

# ─────────────── Google OAuth ───────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─────────────── Sentry (Error Tracking) ───────────────
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# ─────────────── NMLS Verification ───────────────
NMLS_USE_MOCK=true
# NMLS_API_KEY=

# ─────────────── Data Providers ───────────────
DATA_PROVIDER=datagod
DATA_PROVIDER_FALLBACK_ENABLED=true
# DATAGOD_API_KEY=
# CORELOGIC_API_KEY=
# CORELOGIC_API_SECRET=
# REDR_API_KEY=
# MODEX_API_KEY=

# ─────────────── Cloud Storage (S3/R2) ───────────────
STORAGE_BACKEND=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=facemortgage-uploads
# S3_ENDPOINT_URL=        # For Cloudflare R2 or S3-compatible
# S3_PUBLIC_URL_BASE=     # CDN prefix

# ─────────────── Cookie Settings ───────────────
COOKIE_SECURE=false              # Set true in production (HTTPS)
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=.facemortgage.com  # Set in production
